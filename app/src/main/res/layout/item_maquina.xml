<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Info da máquina -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNomeMaquina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Motor Esteira A1"
                android:textColor="#1A1C1E"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSetorMaquina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setor: Linha 1"
                android:textColor="#666666"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvCriticidadeMaquina"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Criticidade: Alta"
                android:textColor="#888888"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Badge de Saúde -->
        <TextView
            android:id="@+id/tvStatusMaquina"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ok"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:background="@drawable/badge_status" />

    </LinearLayout>
</androidx.cardview.widget.CardView>