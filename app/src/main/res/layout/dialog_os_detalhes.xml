<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <View
        android:id="@+id/headerDetails"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#3A8DFF"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="28dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Voltar"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@android:color/white" />

    <!-- ✅ tvIdDemanda → tvDialogOSId -->
    <TextView
        android:id="@+id/tvDialogOSId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Chamado #1294"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardMachineInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvDialogOSId">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DETALHES DO EQUIPAMENTO"
                android:textColor="#3A8DFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- ✅ tvMachineName → tvDialogOSTipo -->
            <TextView
                android:id="@+id/tvDialogOSTipo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Impressora Industrial HP - Setor A"
                android:textColor="#1A1C1E"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- ✅ tvProblemDescription → tvDialogOSDescricao -->
            <TextView
                android:id="@+id/tvDialogOSDescricao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Problema: Falha de aquecimento no fusor e erro de conexão."
                android:textColor="#64748B" />

            <!-- ✅ tvDialogOSSolicitante adicionado (gone — não impacta visual) -->
            <TextView
                android:id="@+id/tvDialogOSSolicitante"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <!-- ✅ tvDialogOSData adicionado (gone — não impacta visual) -->
            <TextView
                android:id="@+id/tvDialogOSData"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:textColor="#94A3B8"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/labelAcoes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="Ações Realizadas"
        android:textColor="#1A1C1E"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardMachineInfo" />

    <!-- ✅ Label + Spinner de Status — mesmo estilo do labelAcoes -->
    <TextView
        android:id="@+id/labelStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:text="Atualizar Status:"
        android:textColor="#1A1C1E"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/labelAcoes" />

    <!-- ✅ spDialogOSStatus adicionado — mesmo estilo visual da tela -->
    <Spinner
        android:id="@+id/spDialogOSStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/labelStatus" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutAcoes"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnFinalizar"
        app:layout_constraintTop_toBottomOf="@id/spDialogOSStatus">

        <!-- ✅ etAcoes → etDialogOSObservacao -->
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDialogOSObservacao"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top"
            android:hint="Descreva o que foi feito..."
            android:inputType="textMultiLine" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/btnFinalizar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:backgroundTint="#10B981"
        android:text="FINALIZAR ATENDIMENTO"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>